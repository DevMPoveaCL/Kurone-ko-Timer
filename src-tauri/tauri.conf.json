{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KURONE-KO",
  "version": "1.0.0",
  "identifier": "com.kuroneko.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "dashboard",
        "title": "KURONE-KO",
        "width": 360,
        "height": 640,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "alwaysOnTop": false,
        "visible": true
      },
      {
        "label": "timer",
        "title": "KURONE-KO",
        "width": 300,
        "height": 150,
        "minWidth": 300,
        "minHeight": 150,
        "maxWidth": 300,
        "maxHeight": 150,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "alwaysOnTop": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
